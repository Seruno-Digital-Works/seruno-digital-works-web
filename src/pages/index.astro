---
import App from "../components/App";
import "../styles/global.css";
---

<html lang="nl">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO -->
		<title>Seruno Digital Works – Webontwikkeling & Digitale Oplossingen</title>
		<meta name="description" content="Seruno Digital Works is uw partner voor webontwikkeling, e-commerce, websiteonderhoud en AI-integratie. Wij bouwen snelle, moderne en schaalbare websites." />
		<meta name="keywords" content="webontwikkeling, webdesign, e-commerce, webshop, SEO, AI, Nederland, Seruno Digital Works" />
		<meta name="author" content="Seruno Digital Works" />
		<meta name="robots" content="index, follow" />

		<!-- Open Graph -->
		<meta property="og:title" content="Seruno Digital Works – Webontwikkeling & Digitale Oplossingen" />
		<meta property="og:description" content="Wij bouwen snelle, moderne en schaalbare websites en webshops. Van concept tot lancering — uw digitale partner voor groei." />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="nl_NL" />
		<meta property="og:site_name" content="Seruno Digital Works" />

		<!-- Preconnect -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	</head>
	<body class="bg-white text-navy-950">
		<App client:load />
	</body>
</html>
